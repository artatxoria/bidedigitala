---
import '../styles/ia-centros-educativos.css';
import NavegacionPrincipal from './NavegacionPrincipal.astro';
---

<!doctype html>
<html lang="eu">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ikastetxeetarako IA Prestakuntza | Bide Digitala</title>
    <meta
      name="description"
      content="Ikastetxeetarako Adimen Artifizial Sortzaileari buruzko prestakuntza praktikoa. Lan-karga gutxiago, eragin humano handiagoa."
    />
  </head>

  <body>
    <div class="page">

      <!-- HEADER -->
      <header>
        <div class="nav-inner">
          <div class="nav-top">
            <a href="/eu" class="logo">
              <img src="/images/BideDigitala.png" alt="BideDigitalaren logotipoa" />
            </a>
            <NavegacionPrincipal lang="eu" />
          </div>
        </div>
      </header>

      <!-- MAIN -->
      <main class="container">

        <!-- HERO -->
        <section class="hero">
            <div class="hero-overlay">
                <div class="container">              
                        <h1>Eraldatu zure Ikastetxea Adimen Artifizialarekin: Lan-zama Gutxiago, Giza Eragin Handiagoa.</h1>
                        <p>Adimen Artifizial Sortzaileari buruzko prestakuntza praktikoa irakasle eta administratzaileentzat. Aurreztu denbora, automatizatu zereginak eta pertsonalizatu hezkuntza.</p>
                        <a href="#cta" class="btn">Informazioa Eskatu</a>
                </div>
            </div>
        </section>

        <!-- ARAZOA -->
         <section class="problem">
            <div class="container section-with-image">
                <div class="image-column">
                    <img src="https://images.unsplash.com/photo-1543269865-cbf427effbad?q=80&w=1740&auto=format&fit=crop" alt="Profesionales educativos colaborando en un entorno de trabajo">
                </div>
                <div class="text-column">
                        <h2>Ezaguna egiten zaizu?</h2>
                        <div class="problem-grid">
                            <div class="problem-item"><h3>Irakasleak</h3><p>Ordu amaigabeak eskolak prestatzen, zuzenketak egiten eta administrazio-lanak kudeatzen.</p></div>
                            <div class="problem-item"><h3>Administratzaileak</h3><p>Etengabeko posta-fluxua, dokumentuen kudeaketa eta behin eta berriz galdera berdinei erantzutea.</p></div>
                            <div class="problem-item"><h3>Taldeak</h3><p>Teknologia hura erabiltzen ikasteko dagoen denbora baino azkarrago doanaren sentsazioa.</p></div>
                        </div>
                </div>
            </div>
        </section>

        <!-- KONPONBIDEA -->
        <section class="solution">
            <div class="container section-with-image reverse">
                 <div class="image-column">
                    <img src="https://images.unsplash.com/photo-1516321497487-e288fb19713f?q=80&w=1740&auto=format&fit=crop" alt="Equipo trabajando con tecnología de forma colaborativa y positiva">
                </div>
                <div class="text-column">
                    <div class="solution-content">
                            <h2>Konponbidea: Hezkuntzaren Mundu Errealerako Sortutako Prestakuntza</h2>
                            <p>Ikastaro %100 praktiko eta egokitua aurkezten dizugu, zure taldeari Adimen Artifizial Sortzailea modu eraginkor eta etikoan erabiltzeko trebetasunak emango dizkiona. Hau ez da zientzia-fikzioa, zure egunerokotasunerako tresnak dira.</p>
                            <h3>Zure Ikastetxera Erabat Egokitua</h3>
                            <p>Prestakuntza <strong>euskaraz</strong>, <strong>gaztelaniaz</strong> edo <strong>formatu elebidunean</strong> ematen da.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- ONURAK -->
        <section class="benefits">
            <div class="container">
              <h2>Zuzeneko Onurak zure Taldearentzat</h2>
                <div class="benefits-grid">
                    <div class="benefits-col">
                        <h3>Irakasleentzat</h3>
                        <ul>
                          <li><strong>Aurreztu Denbora:</strong> Automatizatu plangintza eta ariketen sorkuntza.</li>
                          <li><strong>Pertsonalizatu Ikaskuntza:</strong> Sortu ikasle bakoitzari egokitutako baliabideak.</li>
                          <li><strong>Sustatu zure Sormena:</strong> Sortu ideia eta material berritzaileak.</li>
                        </ul>
                    </div>
                    <div class="benefits-col">
                        <h3>Administratzaileentzat</h3>
                        <ul>
                          <li><strong>Optimizatu Kudeaketa:</strong> Automatizatu mezu eta akten idazketa.</li>
                          <li><strong>Murriztu Kontsulta Zama:</strong> Sortu erantzun automatikoko sistemak.</li>
                          <li><strong>Modernizatu zure Prozesuak:</strong> Egin lan modu arinago eta eraginkorragoan.</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- FROGA SOZIALA -->
        <section class="proof">
            <div class="container">
                <h2>Benetako Esperientzia, Egiaztatutako Emaitzak</h2>
                <div class="proof-box">
                    <p>"Gure prestakuntza-metodologia arrakastaz balioztatu da <strong>Arabako lanbide-heziketako ikastetxe ezagun batean</strong>. Ikastaroak bertako taldeari Adimen Artifiziala egunerokoan txertatzen lagundu zion, haien eraginkortasuna hobetuz eta balio handiagoko zereginetarako denbora askatuz."</p>
                </div>
            </div>
        </section>

        <!-- CTA -->
        <section id="cta" class="cta-final">
            <div class="container">
              <h2>Prest zure ikastetxera Adimen Artifiziala eramateko?</h2>
              <p>Hitz egin dezagun konpromisorik gabe. Eskatu online bilera labur bat zure ikastetxearen behar espezifikoak aztertzeko, eta neurrira egindako prestakuntza-proposamen bat aurkeztuko dizugu.</p>
              <a href="mailto:info@bidedigitala.eus" class="btn" target="_blank">Bai, Gehiago Jakin Nahi Dut</a>
            </div>
        </section>

      </main>

      <!-- FOOTER -->
    <footer class="footer">
        <div class="container">
            <p>&copy; 2026 Bide Digitala. Eskubide guztiak erreserbatuta.</p>
        </div>
    </footer>

    </div>
  </body>
</html>

