---
// src/components/Hero.astro
import { t } from "../lib/translations";

const { lang } = Astro.props;
---

<section id="inicio" class="hero">
  <div class="hero-background" aria-hidden="true">
    <span class="shape shape-1"></span>
    <span class="shape shape-2"></span>
    <span class="shape shape-3"></span>
  </div>

  <div class="container">
    <div class="hero-content">
      <p class="hero-trust">
        <i class="fas fa-shield-halved" aria-hidden="true"></i>
        <span>{t(lang, "hero.trustBadge")}</span>
      </p>

      <h1 class="hero-title">
        <span>{t(lang, "hero.title")}</span>
        <span class="highlight">{t(lang, "hero.title_")}</span>
      </h1>

      <p class="hero-subtitle">{t(lang, "hero.subtitle")}</p>

      <div class="hero-cta">
        <a href="#contacto" class="btn btn-primary">
          <i class="fas fa-rocket" aria-hidden="true"></i>
          {t(lang, "hero.contacto")}
        </a>
        <a href="#diferenciadores" class="btn btn-secondary">
          <i class="fas fa-play" aria-hidden="true"></i>
          {t(lang, "hero.diferencia")}
        </a>
      </div>

      <ul class="hero-metrics">
        <li>
          <span class="metric-value">{t(lang, "hero.metric1Value")}</span>
          <span class="metric-label">{t(lang, "hero.metric1Label")}</span>
        </li>
        <li>
          <span class="metric-value">{t(lang, "hero.metric2Value")}</span>
          <span class="metric-label">{t(lang, "hero.metric2Label")}</span>
        </li>
        <li>
          <span class="metric-value">{t(lang, "hero.metric3Value")}</span>
          <span class="metric-label">{t(lang, "hero.metric3Label")}</span>
        </li>
      </ul>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: linear-gradient(160deg, var(--color-bg-secondary) 0%, var(--color-bg) 60%);
  }

  /* --- Formas decorativas (derivadas de la marca, opacidad baja) --- */
  .hero-background {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .shape {
    position: absolute;
    border-radius: 50%;
    background: var(--color-purple-light);
    opacity: 0.16;
    filter: blur(8px);
    animation: hero-float 8s ease-in-out infinite;
  }

  .shape-1 {
    width: 320px;
    height: 320px;
    top: 8%;
    right: 8%;
    animation-delay: 0s;
  }

  .shape-2 {
    width: 220px;
    height: 220px;
    bottom: 16%;
    left: 4%;
    background: var(--color-purple);
    opacity: 0.1;
    animation-delay: 2s;
  }

  .shape-3 {
    width: 160px;
    height: 160px;
    top: 48%;
    right: 28%;
    animation-delay: 4s;
  }

  @keyframes hero-float {
    0%,
    100% {
      transform: translateY(0) rotate(0deg);
    }
    50% {
      transform: translateY(-22px) rotate(12deg);
    }
  }

  /* --- Contenido --- */
  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 820px;
    margin: 0 auto;
  }

  .hero-trust {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.9rem;
    margin-bottom: 1.75rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-purple);
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.02em;
  }

  .hero-title {
    margin-bottom: 1.5rem;
    color: var(--color-text-primary);
  }

  .hero-title span {
    display: block;
  }

  .highlight {
    background: linear-gradient(135deg, var(--color-purple), var(--color-blue));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .hero-subtitle {
    max-width: 620px;
    margin: 0 auto 2.5rem;
    color: var(--color-text-secondary);
    font-size: 1.2rem;
    line-height: 1.6;
  }

  /* --- CTAs: override de color con tokens (las clases .btn-* son globales) --- */
  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .hero-cta .btn-primary {
    background: linear-gradient(135deg, var(--color-purple), var(--color-blue));
    color: var(--color-text-invert);
    box-shadow: 0 12px 28px rgba(110, 79, 158, 0.35);
  }

  .hero-cta .btn-primary:hover {
    box-shadow: 0 16px 40px rgba(110, 79, 158, 0.45);
  }

  .hero-cta .btn-secondary {
    background: transparent;
    color: var(--color-purple);
    border: 2px solid var(--color-purple);
  }

  .hero-cta .btn-secondary:hover {
    background: var(--color-purple);
    color: var(--color-text-invert);
  }

  /* --- Fila de métricas --- */
  .hero-metrics {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2.5rem;
  }

  .hero-metrics li {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 96px;
  }

  .metric-value {
    font-family: var(--font-primary);
    font-size: 2.25rem;
    font-weight: 700;
    line-height: 1;
    color: var(--color-purple);
  }

  .metric-label {
    margin-top: 0.4rem;
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  @media (max-width: 768px) {
    .hero-cta {
      flex-direction: column;
      align-items: center;
    }

    .hero-metrics {
      gap: 1.75rem;
    }

    .metric-value {
      font-size: 1.9rem;
    }
  }

  @media (max-width: 480px) {
    .hero-subtitle {
      font-size: 1rem;
    }
  }
</style>
